# Halal Tracker — environment variables
# Salin ke `.env` dan isi nilai sebenar. JANGAN commit `.env`.
# Di pengeluaran, set melalui systemd drop-in (Environment=...), bukan fail .env.

# Google OAuth Client ID (PUBLIC — bukan rahsia). Kosong = fallback login password.
GOOGLE_CLIENT_ID=

# Emel admin (dipisah koma untuk lebih dari satu). Emel ini dapat akses panel admin.
ADMIN_EMAIL=admin@example.com

# Laluan fail data.json yang dibaca oleh app (lalai: <dir app>/data.json)
HALAL_DATA=/opt/halal-tracker/data.json

# Folder simpan gambar sijil yang dimuat naik (lalai: <dir app>/uploads)
HALAL_UPLOADS=/opt/halal-tracker/uploads

# Umur cache MyeHalal dalam hari sebelum disoal semula (lalai: 14)
HALAL_TTL_DAYS=14
